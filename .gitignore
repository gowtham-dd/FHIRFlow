# Keep empty directories with .gitkeep
!.gitkeep

# Data directory - explicitly ignore everything except .gitkeep
data/*
!data/.gitkeep

# Uploads directory - explicitly ignore everything except .gitkeep
uploads/*
!uploads/.gitkeep

# Audio output
**/audio_output/*
